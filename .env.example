# ─── Base de datos (PostgreSQL / Neon) ──────────────────────
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ─── Clerk (autenticación) ───────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# ─── Administración ──────────────────────────────────────────
# ID de usuario de Clerk que actúa como administrador único.
# OBLIGATORIA: sin ella, nadie tiene acceso de admin (falla cerrado).
ADMIN_USER_ID="user_..."

# ─── IA (Google Gemini vía AI SDK) ───────────────────────────
GOOGLE_GENERATIVE_AI_API_KEY="AIza..."

# ─── Cloudinary (almacenamiento de PDFs y media) ─────────────
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ─── Stripe (suscripciones — actualmente solo visual) ────────
STRIPE_API_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ─── Pusher (tiempo real: PvP y torneos) ─────────────────────
PUSHER_APP_ID=""
PUSHER_KEY=""
PUSHER_SECRET=""
PUSHER_CLUSTER="us2"
NEXT_PUBLIC_PUSHER_KEY=""
NEXT_PUBLIC_PUSHER_CLUSTER="us2"

# ─── Cron (protege /api/cron/*) ──────────────────────────────
# Genera un valor aleatorio largo. Vercel lo envía como "Authorization: Bearer <valor>".
CRON_SECRET=""

# ─── App ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
